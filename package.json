{
  "name": "campaign-manager",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"yarn workspace backend dev\" \"yarn workspace frontend dev\"",
    "dev:backend": "yarn workspace backend dev",
    "dev:frontend": "yarn workspace frontend dev",
    "build": "yarn workspaces foreach -A -p run build",
    "build:backend": "yarn workspace backend build",
    "build:frontend": "yarn workspace frontend build",
    "test": "yarn workspaces foreach -A -p run test",
    "test:backend": "yarn workspace backend test",
    "lint": "yarn workspaces foreach -A -p run lint",
    "lint:fix": "yarn workspaces foreach -A run lint:fix",
    "db:migrate": "yarn workspace backend db:migrate",
    "db:seed": "yarn workspace backend db:seed",
    "db:rollback": "yarn workspace backend db:rollback"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^6.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "yarn@4.1.1"
}
